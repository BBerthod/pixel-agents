# Pixel Agents Standalone Server Configuration

# Server port
PORT=4242

# SSH host for vscode:// remote links (click agent → open VS Code terminal)
# Leave empty to disable remote links
SSH_HOST=

# Only scan a specific project hash (leave empty for all projects)
# The hash is derived from the workspace path: /path/to/project → -path-to-project
# PROJECT_FILTER=

# How long an agent stays visible after last activity (ms, default: 30min)
INACTIVE_TIMEOUT_MS=1800000

# Default threshold for adopting existing sessions at startup (ms, default: 30min)
NEW_FILE_THRESHOLD_MS=1800000

# Shorter threshold for high-churn projects (ms, default: 3min)
NEW_FILE_THRESHOLD_SHORT_MS=180000

# Comma-separated project names that use the short threshold
SHORT_THRESHOLD_PROJECTS=

# Comma-separated project names to completely exclude from scanning
EXCLUDED_PROJECTS=
